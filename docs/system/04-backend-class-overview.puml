@startuml Backend class overview

skinparam classAttributeIconSize 0

package "Contracts" {
  class CreateRecipeRequest
  class UpdateRecipeRequest
  class RecipeResponse
  class CreateGalleryImageRequest
  class GalleryImageResponse
  class LoginAdminRequest
  class AdminSessionResponse
}

package "Domain" {
  class Recipe
  class GalleryImage
}

package "Services" {
  interface IRecipeService
  class RecipeService {
    +GetPublishedRecipes(search, category)
    +GetPublishedRecipeBySlug(slug)
    +GetAllRecipes(search, category)
    +GetRecipeBySlug(slug)
    +CreateRecipe(request)
    +UpdateRecipe(currentSlug, request)
    +DeleteRecipe(slug)
  }

  interface IGalleryService
  class GalleryService {
    +GetAllImages()
    +CreateImage(request)
    +DeleteImage(id)
  }
}

package "Infrastructure" {
  class AdminAuthorizationFilter {
    +OnAuthorizationAsync(context)
  }
  class AdminSessionStore
}

package "Repositories" {
  interface IRecipeRepository {
    +GetAll()
    +GetBySlug(slug)
    +Add(recipe)
    +Replace(currentSlug, recipe)
    +Delete(slug)
  }

  class InMemoryRecipeRepository
  class FileRecipeRepository
  class SqliteRecipeRepository
  class RecipeSeedData

  interface IGalleryRepository {
    +GetAll()
    +GetById(id)
    +Add(image)
    +Delete(id)
  }

  class InMemoryGalleryRepository
  class FileGalleryRepository
  class SqliteGalleryRepository
  class GallerySeedData
}

package "Data" {
  class RecipeDbContext
  class RecipeDbInitializer
  class RecipeEntity
  class GalleryImageEntity
}

IRecipeService <|.. RecipeService
RecipeService --> IRecipeRepository
RecipeService ..> CreateRecipeRequest
RecipeService ..> UpdateRecipeRequest
RecipeService ..> RecipeResponse
RecipeService ..> Recipe

IGalleryService <|.. GalleryService
GalleryService --> IGalleryRepository
GalleryService ..> CreateGalleryImageRequest
GalleryService ..> GalleryImageResponse
GalleryService ..> GalleryImage

AdminAuthorizationFilter --> AdminSessionStore

IRecipeRepository <|.. InMemoryRecipeRepository
IRecipeRepository <|.. FileRecipeRepository
IRecipeRepository <|.. SqliteRecipeRepository

IGalleryRepository <|.. InMemoryGalleryRepository
IGalleryRepository <|.. FileGalleryRepository
IGalleryRepository <|.. SqliteGalleryRepository

InMemoryRecipeRepository ..> RecipeSeedData
FileRecipeRepository ..> RecipeSeedData
SqliteRecipeRepository --> RecipeDbContext
InMemoryGalleryRepository ..> GallerySeedData
FileGalleryRepository ..> GallerySeedData
SqliteGalleryRepository --> RecipeDbContext
RecipeDbInitializer --> RecipeDbContext
RecipeDbInitializer ..> RecipeSeedData
RecipeDbInitializer ..> GallerySeedData
RecipeDbContext --> RecipeEntity
RecipeDbContext --> GalleryImageEntity

note right of RecipeService
Innehaller:
- filtrering
- payload-normalisering
- slug-krockskontroll
- mapping till RecipeResponse
end note

note right of AdminAuthorizationFilter
Tillater adminanrop via:
- session cookie
- fallback API key header
end note

@enduml
