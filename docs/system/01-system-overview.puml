@startuml
title Recipe App - system overview

actor "Besokare" as Visitor
actor "Admin" as Admin

rectangle "Frontend (React + Vite)" {
  component "HomePage" as HomePage
  component "RecipeDetailsPage" as RecipeDetailsPage
  component "GalleryPage" as GalleryPage
  component "RecipeSuggestionsPage" as RecipeSuggestionsPage
  component "AdminLoginPage" as AdminLoginPage
  component "AdminDashboardPage" as AdminDashboardPage
  component "AdminGalleryPage" as AdminGalleryPage
  component "AdminRecipeEditorPage" as AdminRecipeEditorPage
  component "React Query hooks" as Hooks
  component "API facades\nlib/api/*/*.ts" as ApiFacade
}

rectangle "Backend (ASP.NET Core controllers)" {
  component "Controllers" as Controllers
  component "AdminAuthorizationFilter" as Filter
  component "AdminSessionStore" as SessionStore
  component "RecipeService" as RecipeService
  component "RecipeSuggestionService" as RecipeSuggestionService
  component "GalleryService" as GalleryService
  interface "IRecipeRepository" as RecipeRepo
  interface "IGalleryRepository" as GalleryRepo
  component "EfRecipeRepository" as EfRecipeRepo
  component "EfGalleryRepository" as EfGalleryRepo
  component "RecipeDbContext" as DbContext
}

database "PostgreSQL\nDocker Compose / Testcontainers" as Postgres

Visitor --> HomePage
Visitor --> RecipeDetailsPage
Visitor --> GalleryPage
Visitor --> RecipeSuggestionsPage
Admin --> AdminLoginPage
Admin --> AdminDashboardPage
Admin --> AdminGalleryPage
Admin --> AdminRecipeEditorPage

HomePage --> Hooks
RecipeDetailsPage --> Hooks
GalleryPage --> Hooks
RecipeSuggestionsPage --> Hooks
AdminLoginPage --> Hooks
AdminDashboardPage --> Hooks
AdminGalleryPage --> Hooks
AdminRecipeEditorPage --> Hooks

Hooks --> ApiFacade
ApiFacade --> Controllers

Controllers --> Filter
Filter --> SessionStore
Controllers --> RecipeService
Controllers --> RecipeSuggestionService
Controllers --> GalleryService
RecipeService --> RecipeRepo
GalleryService --> GalleryRepo
RecipeRepo <|.. EfRecipeRepo
GalleryRepo <|.. EfGalleryRepo
EfRecipeRepo --> DbContext
EfGalleryRepo --> DbContext
DbContext --> Postgres

@enduml
